{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "skybedrock:amethyst_shine",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "particles/amethyst_shine"
      }
    },
    "components": {
      // variables
	  "minecraft:particle_initialization": {
		"per_render_expression": "v.size = math.pow(1.0-(v.particle_age / v.particle_lifetime), 0.16); v.alpha = 1.0 - (v.particle_age / v.particle_lifetime);"
	  },
      // appearance
      "minecraft:particle_appearance_billboard": {
        "size": [ "0.4125 * v.size", "0.4125 * v.size" ],
        "facing_camera_mode": "lookat_xyz"
      },
	  "minecraft:particle_appearance_tinting": {
	  	"color": [1, 1, 1, "v.alpha"]
	  },
      // movement
      "minecraft:particle_initial_speed": "Math.random(-0.05, 0.05)",
      "minecraft:emitter_shape_point": {
        "direction": [ "Math.random(-0.02, 0.02)", "Math.random(-0.02, 0.02)", "Math.random(-0.02, 0.02)" ]
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [ "Math.random(-2, 2)", "Math.random(-2, 2)", "Math.random(-2, 2)" ]
      },
      // time
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": 1.8
      },
      // emmiter behaviors
      "minecraft:emitter_rate_instant": { "num_particles": 1 },
      "minecraft:emitter_lifetime_once": {}
    }
  }
}
